<UserControl x:Class="FlipFlatPanel.Controller.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource PanelBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
        <StackPanel>
            <TextBlock Text="E I N S T E L L U N G E N  ( v 3 . 0 )" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextDim}" Margin="0,0,0,12"/>

            <!-- Open Position -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Open Position:" Foreground="{StaticResource TextLight}"
                           FontSize="12" VerticalAlignment="Center"/>
                <Slider x:Name="sliderOpen" Grid.Column="1" Minimum="500" Maximum="2500"
                        Value="2500" IsSnapToTickEnabled="True" TickFrequency="10"
                        VerticalAlignment="Center" IsEnabled="False"
                        ValueChanged="SliderOpen_Changed"/>
                <TextBlock x:Name="txtOpenValue" Grid.Column="2" Text="2500" Foreground="{StaticResource AccentBlue}"
                           FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="µs" Foreground="{StaticResource TextDim}"
                           FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0"/>
            </Grid>

            <!-- Close Position -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Close Position:" Foreground="{StaticResource TextLight}"
                           FontSize="12" VerticalAlignment="Center"/>
                <Slider x:Name="sliderClose" Grid.Column="1" Minimum="500" Maximum="2500"
                        Value="540" IsSnapToTickEnabled="True" TickFrequency="10"
                        VerticalAlignment="Center" IsEnabled="False"
                        ValueChanged="SliderClose_Changed"/>
                <TextBlock x:Name="txtCloseValue" Grid.Column="2" Text="540" Foreground="{StaticResource AccentBlue}"
                           FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="µs" Foreground="{StaticResource TextDim}"
                           FontSize="11" VerticalAlignment="Center" Margin="2,0,0,0"/>
            </Grid>

            <!-- Speed -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="55"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Geschwindigkeit:" Foreground="{StaticResource TextLight}"
                           FontSize="12" VerticalAlignment="Center"/>
                <Slider x:Name="sliderSpeed" Grid.Column="1" Minimum="1" Maximum="10"
                        Value="5" IsSnapToTickEnabled="True" TickFrequency="1"
                        VerticalAlignment="Center" IsEnabled="False"
                        ValueChanged="SliderSpeed_Changed"/>
                <TextBlock x:Name="txtSpeedValue" Grid.Column="2" Text="5" Foreground="{StaticResource AccentBlue}"
                           FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Speed Labels -->
            <Grid Margin="130,0,55,8">
                <TextBlock Text="Langsam" FontSize="10" Foreground="{StaticResource TextDim}"
                           HorizontalAlignment="Left"/>
                <TextBlock Text="Schnell" FontSize="10" Foreground="{StaticResource TextDim}"
                           HorizontalAlignment="Right"/>
            </Grid>

            <!-- SoftClose -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="SoftClose:" Foreground="{StaticResource TextLight}"
                           FontSize="12" VerticalAlignment="Center"/>
                <CheckBox x:Name="chkSoftClose" Grid.Column="1"
                          Content="Sanftes Starten und Stoppen" IsEnabled="False"
                          Foreground="{StaticResource TextLight}" FontSize="12"
                          Checked="SoftClose_Changed" Unchecked="SoftClose_Changed"/>
            </Grid>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                <Button x:Name="btnApply" Content="Anwenden" Width="90" Margin="3,0"
                        Style="{StaticResource PanelButton}"
                        Background="{StaticResource AccentBlue}"
                        IsEnabled="False" Click="Apply_Click"
                        ToolTip="Einstellungen an den Arduino senden"/>
                <Button x:Name="btnSaveEeprom" Content="Speichern (EEPROM)" Width="150" Margin="3,0"
                        Style="{StaticResource PanelButton}"
                        Background="{StaticResource AccentGreen}"
                        IsEnabled="False" Click="SaveEeprom_Click"
                        ToolTip="Einstellungen dauerhaft im Arduino speichern"/>
                <Button x:Name="btnDefaults" Content="Defaults" Width="75" Margin="3,0"
                        Style="{StaticResource PanelButton}"
                        Background="{StaticResource BorderDark}"
                        IsEnabled="False" Click="Defaults_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
