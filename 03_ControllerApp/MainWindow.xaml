<Window x:Class="FlipFlatPanel.Controller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlipFlat Panel Controller v1.2"
        Width="540" Height="860"
        MinWidth="500" MinHeight="750"
        Background="{StaticResource DarkBg}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style x:Key="StatusLed" TargetType="Ellipse">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Stroke" Value="#555"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextLight}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingsValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="42"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menüleiste -->
        <Border Grid.Row="0" Background="#252536" Padding="4,2">
            <StackPanel Orientation="Horizontal">
                <Button Content="Hilfe" Style="{StaticResource MenuButton}" Click="Help_Click"/>
                <Button Content="Über diese App" Style="{StaticResource MenuButton}" Click="About_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="16,8,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>

                <!-- Titel -->
                <StackPanel Grid.Row="0" Margin="0,0,0,14">
                    <TextBlock Text="FlipFlat Panel Controller" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text="Steuerung für Arduino Nano Flat-Field Panel" FontSize="12" Foreground="{StaticResource TextDim}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Verbindung -->
                <Border Grid.Row="1" Background="{StaticResource PanelBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Modus:" Foreground="{StaticResource TextLight}" VerticalAlignment="Center" Margin="0,0,10,8" FontSize="13"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="rbSerial" Content="Direkt (Serial)" Foreground="{StaticResource TextLight}" FontSize="13" IsChecked="True" Margin="0,0,20,0" Checked="Mode_Changed"/>
                            <RadioButton x:Name="rbAscom" Content="ASCOM-Treiber" Foreground="{StaticResource TextLight}" FontSize="13" Checked="Mode_Changed"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                            <Ellipse x:Name="ledConnection" Style="{StaticResource StatusLed}" Fill="#FF6B6B" Margin="0,0,6,0"/>
                            <TextBlock x:Name="txtConnectionStatus" Text="Getrennt" Foreground="{StaticResource TextDim}" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="COM-Port:" Foreground="{StaticResource TextLight}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cmbPorts" Grid.Column="0" FontSize="13" Height="30" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="&#x27F3;" FontSize="16" Width="30" Height="30" Margin="4,0,0,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" Click="RefreshPorts_Click" ToolTip="Ports aktualisieren"/>
                        </Grid>
                        <Button x:Name="btnConnect" Grid.Row="1" Grid.Column="2" Content="Verbinden" Width="110" Style="{StaticResource PanelButton}" Click="Connect_Click"/>
                    </Grid>
                </Border>

                <!-- Cover-Steuerung -->
                <Border Grid.Row="2" Background="{StaticResource PanelBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="C O V E R - S T E U E R U N G" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnOpen" Grid.Column="0" Content="&#x25B2;  ÖFFNEN" Height="44" Style="{StaticResource PanelButton}" Background="{StaticResource AccentGreen}" IsEnabled="False" Click="Open_Click"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0" HorizontalAlignment="Center">
                                <Ellipse x:Name="ledCover" Width="20" Height="20" Fill="#555" Stroke="#777" StrokeThickness="1.5"/>
                                <TextBlock x:Name="txtCoverState" Text="—" Foreground="{StaticResource TextDim}" FontSize="11" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button x:Name="btnClose" Grid.Column="2" Content="&#x25BC;  SCHLIESSEN" Height="44" Style="{StaticResource PanelButton}" Background="{StaticResource AccentOrange}" IsEnabled="False" Click="Close_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Helligkeit -->
                <Border Grid.Row="3" Background="{StaticResource PanelBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="H E L L I G K E I T  ( E L - F O L I E )" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}" Margin="0,0,0,10"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="sliderBrightness" Minimum="0" Maximum="255" Value="0" IsEnabled="False" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="Brightness_Changed"/>
                            <TextBox x:Name="txtBrightnessInput" Grid.Column="1" Width="52" Height="28" Margin="10,0,0,0" FontSize="14" FontWeight="Bold" TextAlignment="Center" VerticalContentAlignment="Center" Background="{StaticResource DarkBg}" Foreground="{StaticResource AccentBlue}" BorderBrush="{StaticResource BorderDark}" BorderThickness="1" IsEnabled="False" Text="0" KeyDown="BrightnessInput_KeyDown" LostFocus="BrightnessInput_LostFocus"/>
                            <Button x:Name="btnBrightnessSend" Grid.Column="2" Content="&#x2713;" Width="28" Height="28" Margin="4,0,0,0" Style="{StaticResource PanelButton}" Background="{StaticResource AccentBlue}" FontSize="14" Padding="0" IsEnabled="False" Click="BrightnessSend_Click" ToolTip="Wert senden"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="btnBright0" Content="AUS" Width="60" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="BrightPreset_Click" Tag="0"/>
                            <Button x:Name="btnBright25" Content="25%" Width="60" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="BrightPreset_Click" Tag="64"/>
                            <Button x:Name="btnBright50" Content="50%" Width="60" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="BrightPreset_Click" Tag="128"/>
                            <Button x:Name="btnBright75" Content="75%" Width="60" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="BrightPreset_Click" Tag="192"/>
                            <Button x:Name="btnBright100" Content="MAX" Width="60" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="BrightPreset_Click" Tag="255"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ========== SERVO-EINSTELLUNGEN (NEU v3.0) ========== -->
                <Border Grid.Row="4" Background="{StaticResource PanelBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="S E R V O - E I N S T E L L U N G E N" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}" Margin="0,0,0,12"/>

                        <!-- Open-Position -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Open-Position:" Style="{StaticResource SettingsLabel}"/>
                            <Slider x:Name="sliderServoOpen" Grid.Column="1" Minimum="500" Maximum="2500" Value="2500" IsEnabled="False" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="10" ValueChanged="ServoOpen_Changed"/>
                            <TextBlock x:Name="txtServoOpen" Grid.Column="2" Text="2500" Style="{StaticResource SettingsValue}"/>
                        </Grid>

                        <!-- Close-Position -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Close-Position:" Style="{StaticResource SettingsLabel}"/>
                            <Slider x:Name="sliderServoClose" Grid.Column="1" Minimum="500" Maximum="2500" Value="540" IsEnabled="False" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="10" ValueChanged="ServoClose_Changed"/>
                            <TextBlock x:Name="txtServoClose" Grid.Column="2" Text="540" Style="{StaticResource SettingsValue}"/>
                        </Grid>

                        <!-- Speed -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Geschwindigkeit:" Style="{StaticResource SettingsLabel}"/>
                            <Slider x:Name="sliderSpeed" Grid.Column="1" Minimum="1" Maximum="10" Value="5" IsEnabled="False" VerticalAlignment="Center" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="Speed_Changed"/>
                            <TextBlock x:Name="txtSpeed" Grid.Column="2" Text="5" Style="{StaticResource SettingsValue}"/>
                        </Grid>

                        <!-- SoftClose -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SoftClose:" Style="{StaticResource SettingsLabel}"/>
                            <CheckBox x:Name="chkSoftClose" Grid.Column="1" Content="Sanftes Starten und Stoppen" Foreground="{StaticResource TextLight}" FontSize="12" IsEnabled="False" VerticalAlignment="Center" Checked="SoftClose_Changed" Unchecked="SoftClose_Changed"/>
                        </Grid>

                        <!-- Buttons: Übernehmen + Speichern + Test -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="btnServoApply" Content="Übernehmen" Width="100" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource AccentBlue}" IsEnabled="False" Click="ServoApply_Click" ToolTip="Einstellungen an Arduino senden (temporär)"/>
                            <Button x:Name="btnServoSave" Content="Speichern" Width="100" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource AccentGreen}" IsEnabled="False" Click="ServoSave_Click" ToolTip="Im EEPROM dauerhaft speichern"/>
                            <Button x:Name="btnServoTestOpen" Content="Test Open" Width="80" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="ServoTestOpen_Click"/>
                            <Button x:Name="btnServoTestClose" Content="Test Close" Width="80" Margin="3,0" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="ServoTestClose_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Firmware + Ping -->
                <Border Grid.Row="5" Background="{StaticResource PanelBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtFirmware" Text="Firmware: —" Foreground="{StaticResource TextDim}" FontSize="12"/>
                        <Button x:Name="btnPing" Grid.Column="1" Content="PING" Width="70" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" IsEnabled="False" Click="Ping_Click"/>
                    </Grid>
                </Border>

                <!-- Log -->
                <Border Grid.Row="6" Background="{StaticResource PanelBg}" CornerRadius="8" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <TextBlock Text="P R O T O K O L L" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
                            <Button Content="Leeren" HorizontalAlignment="Right" Style="{StaticResource PanelButton}" Background="{StaticResource BorderDark}" FontSize="11" Padding="10,3" Click="ClearLog_Click"/>
                        </Grid>
                        <TextBox x:Name="txtLog" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="{StaticResource DarkBg}" Foreground="#AAB8A0" BorderBrush="{StaticResource BorderDark}" FontFamily="Consolas" FontSize="11.5" Padding="6"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
